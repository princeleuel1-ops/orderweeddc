  "scenarios": [
    {
      "id": "text-query",
      "name": "Find a product by text",
      "coverage": ["text"],
      "brandId": "benchmark-primary",
      "filters": {"query": "Blue Comet"},
      "expectedRecordIds": ["entry-blue-store", "entry-blue-delivery"],
      "truthBoundary": {"rule": "tenant-scoped current-or-demonstration visibility", "mustExclude": []},
      "benchmarkOnly": true
    },
    {
      "id": "category-filter",
      "name": "Filter products by category",
      "coverage": ["category"],
      "brandId": "benchmark-primary",
      "filters": {"category": "concentrates"},
      "expectedRecordIds": ["entry-concentrate-store"],
      "truthBoundary": {"rule": "category filter preserves public evidence eligibility", "mustExclude": []},
      "benchmarkOnly": true
    },
    {
      "id": "strain-type-filter",
      "name": "Filter products by strain type",
      "coverage": ["strain type"],
      "brandId": "benchmark-primary",
      "filters": {"strainType": "indica"},
      "expectedRecordIds": ["entry-concentrate-store"],
      "truthBoundary": {"rule": "strain filter does not infer effects or suitability", "mustExclude": []},
      "benchmarkOnly": true
    },
    {
      "id": "service-type-filter",
      "name": "Filter products by service type",
      "coverage": ["service type"],
      "brandId": "benchmark-primary",
      "filters": {"serviceType": "delivery"},
      "expectedRecordIds": ["entry-blue-delivery", "entry-solar-delivery", "entry-price-high", "entry-demo-topical"],
      "truthBoundary": {"rule": "retailer service type remains tenant and evidence scoped", "mustExclude": []},
      "benchmarkOnly": true
    },
    {
      "id": "verified-current-filter",
      "name": "Show only verified current records",
      "coverage": ["verified-current"],
      "brandId": "benchmark-primary",
      "filters": {"evidence": "VERIFIED_CURRENT"},
      "expectedRecordIds": ["entry-blue-store", "entry-blue-delivery", "entry-solar-delivery", "entry-concentrate-store", "entry-price-low", "entry-price-high"],
      "truthBoundary": {"rule": "retailer, product, and menu evidence are all current", "mustExclude": ["entry-demo-topical", "entry-stale-beacon"]},
      "benchmarkOnly": true
    },
    {
      "id": "demonstration-only-filter",
      "name": "Show only demonstration records",
      "coverage": ["demonstration-only"],
      "brandId": "benchmark-primary",
      "filters": {"evidence": "DEMONSTRATION_ONLY"},
      "expectedRecordIds": ["entry-demo-topical"],
      "truthBoundary": {"rule": "at least one chain record is explicitly demonstration data", "mustExclude": ["entry-blue-store"]},
      "benchmarkOnly": true
    },
    {
      "id": "reported-stock-filter",
      "name": "Filter by reported stock",
      "coverage": ["reported stock"],
      "brandId": "benchmark-primary",
      "filters": {"stock": "IN_STOCK"},
      "expectedRecordIds": ["entry-blue-store", "entry-blue-delivery", "entry-concentrate-store", "entry-price-low", "entry-price-high", "entry-demo-topical"],
      "truthBoundary": {"rule": "reported stock is bounded by evidence visibility and is not a live inventory claim", "mustExclude": ["entry-solar-delivery", "entry-stale-beacon"]},
      "benchmarkOnly": true
    },
    {
      "id": "price-band-filter",
      "name": "Filter products by price band",
      "coverage": ["price band"],
      "brandId": "benchmark-primary",
      "filters": {"priceBand": "25_TO_50"},
      "expectedRecordIds": ["entry-blue-store", "entry-blue-delivery"],
      "truthBoundary": {"rule": "bounded price filter preserves tenant and freshness constraints", "mustExclude": ["entry-stale-beacon", "entry-other-tenant"]},
      "benchmarkOnly": true
    },
    {
      "id": "price-ordering",
      "name": "Order matching products by price",
