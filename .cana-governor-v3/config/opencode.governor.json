{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "autoupdate": false,
  "provider": {
    "cana_lane_1": {
      "name": "CANA OpenRouter Lane 1",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:CANA_LANE_1_API_KEY}",
        "headers": {
          "HTTP-Referer": "https://orderweeddc.com",
          "X-OpenRouter-Title": "CANA Governor Lane 1"
        }
      },
      "models": {
        "tencent/hy3:free": {
          "name": "Tencent Hy3 Free",
          "limit": { "context": 262144, "output": 32768 },
          "variants": { "high": { "reasoning": { "effort": "high" } } }
        }
      }
    },
