# Production environment variables for the cPanel Node.js app.
# Enter these in cPanel > Setup Node.js App > Environment variables.
# NO SECRETS BELONG IN THIS FILE — it is a template committed to git.

# REQUIRED. Persistent SQLite database OUTSIDE the release directory so
# deployments and rollbacks never touch data. Replace <cpanel-user>.
DATABASE_URL=file:/home/<cpanel-user>/orderweeddc-data/prod.db

# REQUIRED.
NODE_ENV=production

# OPTIONAL. Extra allowed request hostnames (comma-separated) beyond the
# built-in platform list (orderweeddc.com and www are already built in).
# CANA_ALLOWED_HOSTS=

# NOT USED IN PRODUCTION RUNTIME — the public product runtime never calls
# external model APIs. GEMINI_API_KEY belongs only to the operator-side
# ad-creative tooling and is injected per-run, never stored on the server.

# REQUIRED on CloudLinux/CageFS hosts (os-release hidden -> Prisma guesses
# debian). Newer artifacts self-set this in app.js; setting it explicitly is
# always safe. Replace <cpanel-user>.
PRISMA_QUERY_ENGINE_LIBRARY=/home/<cpanel-user>/apps/orderweeddc/current/node_modules/.prisma/client/libquery_engine-rhel-openssl-1.1.x.so.node
